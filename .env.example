# ============================================================
#  Foure & Coeur — Variables d'environnement (exemple)
#  Copier ce fichier en `.env.local` et renseigner les valeurs.
#  Ne jamais commiter `.env.local`.
# ============================================================

# --- Base de données (Neon Postgres) -------------------------
# Récupérer la chaîne de connexion "pooled" sur https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Connexion directe (migrations) — optionnelle selon le provider
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentification (Auth.js / NextAuth v5) ----------------
# Générer avec: npx auth secret  (ou openssl rand -base64 32)
AUTH_SECRET="change-me"
# URL publique du site (prod) — laisser vide en local
AUTH_URL="http://localhost:3000"

# OAuth Google (optionnel, pour "Se connecter avec Google")
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Génération d'images (Google Gemini / "Nano Banana") -----
# Utilisée uniquement par le script `npm run images:generate`
GEMINI_API_KEY=""

# --- E-mails transactionnels (Resend) — Phase 6 --------------
RESEND_API_KEY=""
EMAIL_FROM="Foure & Coeur <commandes@foure-coeur.com>"

# --- WhatsApp ------------------------------------------------
# Numéro destinataire des notifications de commande (format international, sans +)
# Ex: 33612345678
WHATSAPP_TARGET_NUMBER=""
# Provider: "link" (wa.me, défaut) | "meta" (Cloud API officielle, plus tard)
WHATSAPP_PROVIDER="link"
# Pour le provider "meta" (à remplir plus tard) :
WHATSAPP_META_TOKEN=""
WHATSAPP_META_PHONE_ID=""

# --- Stockage des images (Vercel Blob) — Phase 3 -------------
BLOB_READ_WRITE_TOKEN=""

# --- Paiement (Stripe) — plus tard ---------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Configuration publique du site -------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
